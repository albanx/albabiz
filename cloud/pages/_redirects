# Cloudflare Pages redirects / rewrites for the AlbaBiz SPA.
# Clean deep links (/biznes/<slug>, /kategoria/<slug>, /kontea/<slug>,
# /regjistro, /hiq) are handled client-side by app.js. On a hard refresh or
# shared link, Pages must serve index.html (200 rewrite, NOT a 301) so the
# router can take over. Real files (/styles.css, /app.js, /privatesia.html,
# /admin/*) are served first because Pages matches static assets before these
# rules.

# Admin SPA keeps its own routing under /admin (protected by Cloudflare Access).
/admin/*    /admin/index.html   200

# Everything else falls through to the public SPA shell.
/biznes/*      /index.html   200
/kategoria/*   /index.html   200
/kontea/*      /index.html   200
/regjistro     /index.html   200
/hiq           /index.html   200
