{
  "name": "albabiz-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AlbaBiz.ie — Cloudflare Worker API (Albanian Business Network Ireland, an ACAI project)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:init:local": "wrangler d1 execute albabiz-db --local --file=migrations/0001_init.sql",
    "d1:seed:local": "wrangler d1 execute albabiz-db --local --file=migrations/0002_seed.sql",
    "d1:init:remote": "wrangler d1 execute albabiz-db --remote --file=migrations/0001_init.sql",
    "d1:seed:remote": "wrangler d1 execute albabiz-db --remote --file=migrations/0002_seed.sql",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
